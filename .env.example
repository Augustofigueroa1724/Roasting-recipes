# Token personal de la API pública (Settings -> API Tokens en roast.world).
# Cabecera x-api-key. Solo da acceso a TU contenido (FASE 1: roast_index.py).
ROAST_API_TOKEN=

# idToken de Firebase de tu sesión en roast.world (campo root.token de
# window.__remixContext en cualquier página _app). Necesario para la búsqueda
# de comunidad (FASE 2) y para localizar el log de cada receta en la comparativa
# (FASE 2.5: serve.py -> POST /api/v3/proxy). Caduca ~7 días.
ROAST_FIREBASE_TOKEN=

# (Opcional / ya NO necesario) Cookie __session. La comparativa de perfiles usa
# el log público de Firebase Storage, así que el Bearer de arriba basta.
# ROAST_SESSION_COOKIE=
